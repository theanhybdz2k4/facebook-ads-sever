// Facebook Ads Database Schema (Supabase Clone)
// Updated to match Supabase schema exactly

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
  binaryTargets   = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
  output          = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===================================
// ENUMS FROM SUPABASE
// ===================================

enum UnifiedStatus {
  ACTIVE
  PAUSED
  ARCHIVED
  DELETED
  UNKNOWN
}

enum SyncJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// ===================================
// MODELS
// ===================================

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  password     String
  name         String?
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  avatarUrl    String?   @map("avatar_url")
  geminiApiKey String?   @map("gemini_api_key")

  // Relations
  platformIdentities PlatformIdentity[]
  authTokens         AuthToken[]
  refreshTokens      RefreshToken[]
  branches           Branch[]
  cronSettings       CronSetting[]
  aiReports          AiReport[]
  telegramBots       TelegramBot[]
  chatbotConfigs     ChatbotConfig[]
  chatbotFlows       ChatbotFlow[]

  @@map("users")
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Branch {
  id                 Int       @id @default(autoincrement())
  userId             Int       @map("user_id")
  name               String
  code               String?
  createdAt          DateTime  @default(now()) @map("created_at")
  deletedAt          DateTime? @map("deleted_at")
  autoMatchKeywords String[]  @default([]) @map("auto_match_keywords")

  user             User               @relation(fields: [userId], references: [id])
  dailyStats       BranchDailyStat[]
  platformAccounts PlatformAccount[]

  @@map("branches")
}

model BranchDailyStat {
  id                   Int      @id @default(autoincrement())
  branchId             Int      @map("branch_id")
  date                 DateTime @db.Date
  createdAt            DateTime @default(now()) @map("createdAt")
  totalImpressions     BigInt   @default(0) @map("totalImpressions")
  totalResults         BigInt   @default(0) @map("totalResults")
  totalSpend           Decimal  @default(0) @map("totalSpend") @db.Decimal(20, 4)
  totalClicks          BigInt   @default(0) @map("totalClicks")
  platformCode         String   @default("all") @map("platform_code")
  totalMessagingTotal  BigInt?  @default(0) @map("totalMessagingTotal")
  totalMessagingNew    BigInt?  @default(0) @map("totalMessagingNew")
  totalRevenue         Decimal? @default(0) @map("totalRevenue") @db.Decimal(20, 4)

  branch Branch @relation(fields: [branchId], references: [id])

  @@map("branch_daily_stats")
}

model Platform {
  id        Int      @id @default(autoincrement())
  code      String
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  isActive  Boolean  @default(true) @map("is_active")

  identities PlatformIdentity[]
  accounts   PlatformAccount[]

  @@map("platforms")
}

model PlatformIdentity {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  platformId   Int       @map("platform_id")
  externalId   String    @map("external_id")
  name         String?
  isValid      Boolean   @default(true) @map("is_valid")
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  user        User                 @relation(fields: [userId], references: [id])
  platform    Platform             @relation(fields: [platformId], references: [id])
  credentials PlatformCredential[]
  accounts    PlatformAccount[] @relation("IdentityToAccounts")
  pages       PlatformPage[]

  @@map("platform_identities")
}

model PlatformAccount {
  id                 Int       @id @default(autoincrement())
  platformIdentityId Int       @map("platform_identity_id")
  platformId         Int       @map("platform_id")
  externalId         String    @map("external_id")
  name               String?
  accountStatus      String    @map("account_status") // FB API: 1=ACTIVE, 2=DISABLED, etc. as string in Supabase
  currency           String?
  timezone           String?
  platformData       Json?     @map("platform_data")
  syncedAt           DateTime? @map("synced_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  branchId           Int?      @map("branch_id")
  deletedAt          DateTime? @map("deleted_at")

  identity        PlatformIdentity  @relation("IdentityToAccounts", fields: [platformIdentityId], references: [id])
  platform        Platform          @relation(fields: [platformId], references: [id])
  branch          Branch?           @relation(fields: [branchId], references: [id])
  campaigns       UnifiedCampaign[]
  adGroups        UnifiedAdGroup[]
  ads             UnifiedAd[]
  insights        UnifiedInsight[]
  hourlyInsights  UnifiedHourlyInsight[]
  syncJobs        SyncJob[]
  leads           Lead[]
  adCreatives    UnifiedAdCreative[]
  telegramBots    TelegramBot[]

  @@unique([externalId])
  @@map("platform_accounts")
}

model PlatformCredential {
  id                 Int       @id @default(autoincrement())
  platformIdentityId Int       @map("platform_identity_id")
  credentialType     String    @map("credential_type")
  credentialValue    String    @map("credential_value")
  expiresAt          DateTime? @map("expires_at")
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  identity PlatformIdentity @relation(fields: [platformIdentityId], references: [id])

  @@map("platform_credentials")
}

model UnifiedCampaign {
  id                String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  platformAccountId Int            @map("platform_account_id")
  externalId        String         @map("external_id")
  name              String?
  objective         String?
  dailyBudget       Decimal?       @map("daily_budget") @db.Decimal(20, 4)
  lifetimeBudget    Decimal?       @map("lifetime_budget") @db.Decimal(20, 4)
  startTime         DateTime?      @map("start_time")
  endTime           DateTime?      @map("end_time")
  platformData      Json?          @map("platform_data")
  syncedAt          DateTime       @map("synced_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  status            UnifiedStatus  @default(ACTIVE)
  deletedAt         DateTime?      @map("deleted_at")
  effectiveStatus   String?        @map("effective_status")

  account        PlatformAccount @relation(fields: [platformAccountId], references: [id])
  adGroups       UnifiedAdGroup[]
  insights       UnifiedInsight[]
  hourlyInsights UnifiedHourlyInsight[]
  aiAnalysis     CampaignAiAnalysis?

  @@unique([externalId])
  @@map("unified_campaigns")
}

model UnifiedAdGroup {
  id                String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  unifiedCampaignId String         @map("unified_campaign_id")
  platformAccountId Int            @map("platform_account_id")
  externalId        String         @map("external_id")
  name              String?
  dailyBudget       Decimal?       @map("daily_budget") @db.Decimal(20, 4)
  platformData      Json?          @map("platform_data")
  syncedAt          DateTime       @map("synced_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  status            UnifiedStatus  @default(ACTIVE)
  deletedAt         DateTime?      @map("deleted_at")
  optimizationGoal  String?        @map("optimization_goal")
  effectiveStatus   String?        @map("effective_status")
  startTime         DateTime?      @map("start_time")
  endTime           DateTime?      @map("end_time")

  campaign       UnifiedCampaign @relation(fields: [unifiedCampaignId], references: [id])
  account        PlatformAccount @relation(fields: [platformAccountId], references: [id])
  ads            UnifiedAd[]
  insights       UnifiedInsight[]
  hourlyInsights UnifiedHourlyInsight[]

  @@unique([externalId])
  @@map("unified_ad_groups")
}

model UnifiedAd {
  id                  String         @id
  unifiedAdGroupId    String         @map("unified_ad_group_id")
  platformAccountId   Int            @map("platform_account_id")
  externalId          String         @map("external_id")
  name                String?
  syncedAt            DateTime       @map("synced_at")
  createdAt           DateTime       @default(now()) @map("created_at")
  status              UnifiedStatus  @default(ACTIVE)
  deletedAt           DateTime?      @map("deleted_at")
  effectiveStatus     String?        @map("effective_status")
  unifiedAdCreativeId String?        @map("unified_ad_creative_id")
  startTime           DateTime?      @map("start_time")
  endTime             DateTime?      @map("end_time")
  platformData        Json?          @map("platform_data")

  adGroup        UnifiedAdGroup      @relation(fields: [unifiedAdGroupId], references: [id])
  account        PlatformAccount      @relation(fields: [platformAccountId], references: [id])
  creative       UnifiedAdCreative?   @relation(fields: [unifiedAdCreativeId], references: [id])
  insights       UnifiedInsight[]
  hourlyInsights UnifiedHourlyInsight[]

  @@map("unified_ads")
}

model UnifiedInsight {
  id                String    @id @default(dbgenerated("gen_random_uuid()"))
  platformAccountId Int       @map("platform_account_id")
  date              DateTime  @db.Date
  impressions       BigInt?
  clicks            BigInt?
  spend             Decimal?  @db.Decimal(20, 4)
  conversions       BigInt?
  results           BigInt?
  syncedAt          DateTime  @map("synced_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  unifiedAdId       String?   @map("unified_ad_id")
  reach             BigInt?
  unifiedAdGroupId  String?   @map("unified_ad_group_id")
  unifiedCampaignId String?   @map("unified_campaign_id")
  deletedAt         DateTime? @map("deleted_at")
  messagingTotal    BigInt?   @default(0) @map("messaging_total")
  messagingNew      BigInt?   @default(0) @map("messaging_new")
  purchaseValue     Decimal?  @default(0) @map("purchase_value") @db.Decimal(20, 4)

  account  PlatformAccount @relation(fields: [platformAccountId], references: [id])
  ad       UnifiedAd?      @relation(fields: [unifiedAdId], references: [id])
  adGroup  UnifiedAdGroup? @relation(fields: [unifiedAdGroupId], references: [id])
  campaign UnifiedCampaign? @relation(fields: [unifiedCampaignId], references: [id])

  @@unique([platformAccountId, unifiedAdId, date])
  @@map("unified_insights")
}

model SyncJob {
  id                Int           @id @default(autoincrement())
  platformAccountId Int           @map("platform_account_id")
  jobType           String        @map("job_type")
  status            SyncJobStatus @default(PENDING)
  errorMessage      String?       @map("error_message")
  startedAt         DateTime?     @map("started_at")
  completedAt       DateTime?     @map("completed_at")
  createdAt         DateTime      @default(now()) @map("createdAt")
  deletedAt         DateTime?     @map("deleted_at")

  account PlatformAccount @relation(fields: [platformAccountId], references: [id])

  @@map("sync_jobs")
}

model UnifiedHourlyInsight {
  id                String    @id @default(dbgenerated("gen_random_uuid()"))
  platformAccountId Int       @map("platform_account_id")
  unifiedCampaignId String?   @map("unified_campaign_id")
  unifiedAdGroupId  String?   @map("unified_ad_group_id")
  unifiedAdId       String?   @map("unified_ad_id")
  date              DateTime  @db.Date
  hour              Int
  spend             Decimal?  @db.Decimal(20, 4)
  impressions       BigInt?
  clicks            BigInt?
  results           BigInt?
  platformMetrics   Json?     @map("platform_metrics")
  syncedAt          DateTime  @map("synced_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  deletedAt         DateTime? @map("deleted_at")
  messagingTotal    BigInt?   @default(0) @map("messaging_total")
  messagingNew      BigInt?   @default(0) @map("messaging_new")
  purchaseValue     Decimal?  @db.Decimal(20, 4) @map("purchase_value")
  conversions       BigInt?

  account  PlatformAccount  @relation(fields: [platformAccountId], references: [id])
  campaign UnifiedCampaign? @relation(fields: [unifiedCampaignId], references: [id])
  adGroup  UnifiedAdGroup?  @relation(fields: [unifiedAdGroupId], references: [id])
  ad       UnifiedAd?       @relation(fields: [unifiedAdId], references: [id])

  @@unique([platformAccountId, unifiedAdId, date, hour])
  @@map("unified_hourly_insights")
}

model CronSetting {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  cronType     String    @map("cron_type")
  allowedHours Int[]     @map("allowed_hours")
  enabled      Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  lastRunAt    DateTime? @map("last_run_at")

  user User @relation(fields: [userId], references: [id])

  @@map("cron_settings")
}

model TelegramBot {
  id                Int       @id @default(autoincrement())
  userId            Int       @map("user_id")
  platformAccountId Int?      @map("platform_account_id")
  botToken          String    @unique @map("bot_token")
  botName           String?   @map("bot_name")
  botUsername       String?   @map("bot_username")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  user               User               @relation(fields: [userId], references: [id])
  account            PlatformAccount?   @relation(fields: [platformAccountId], references: [id])
  subscribers        TelegramSubscriber[]
  notificationSettings TelegramBotNotificationSetting[]

  @@map("telegram_bots")
}

model TelegramBotNotificationSetting {
  id           Int      @id @default(autoincrement())
  telegramBotId Int      @map("telegram_bot_id")
  allowedHours  Int[]    @map("allowed_hours")
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  bot TelegramBot @relation(fields: [telegramBotId], references: [id])

  @@map("telegram_bot_notification_settings")
}

model TelegramSubscriber {
  id            Int      @id @default(autoincrement())
  telegramBotId Int      @map("telegram_bot_id")
  chatId        String   @map("chat_id")
  name          String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  bot TelegramBot @relation(fields: [telegramBotId], references: [id])

  @@map("telegram_subscribers")
}

model UnifiedAdCreative {
  id                String    @id
  platformAccountId Int       @map("platform_account_id")
  externalId        String    @map("external_id")
  name              String?
  body              String?
  imageUrl          String?   @map("image_url")
  thumbnailUrl      String?   @map("thumbnail_url")
  title             String?
  syncedAt          DateTime  @map("synced_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  platformData      Json?     @map("platform_data")

  account PlatformAccount @relation(fields: [platformAccountId], references: [id])
  ads     UnifiedAd[]

  @@unique([platformAccountId, externalId])
  @@map("unified_ad_creatives")
}

model Lead {
  id                String    @id @default(dbgenerated("gen_random_uuid()"))
  platformAccountId Int       @map("platform_account_id")
  externalId        String    @map("external_id")
  customerName      String?   @map("customer_name")
  customerAvatar    String?   @map("customer_avatar")
  lastMessageAt     DateTime? @map("last_message_at")
  sourceCampaignId  String?   @map("source_campaign_id")
  isQualified       Boolean   @default(false) @map("is_qualified")
  assignedUserId    Int?      @map("assigned_user_id")
  platformData      Json?     @map("platform_data")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @map("updated_at")
  notes             String?
  phone             String?
  isRead            Boolean?  @default(true) @map("is_read")
  metadata          Json?     @default("{}")
  fbPageId          String?   @map("fb_page_id")
  aiAnalysis        String?   @map("ai_analysis")
  isPotential       Boolean?  @map("is_potential")
  isManualPotential Boolean?  @default(false) @map("is_manual_potential")
  lastAnalysisAt    DateTime? @map("last_analysis_at")
  assignedAgentId   String?   @map("assigned_agent_id")
  assignedAgentName String?   @map("assigned_agent_name")
  firstContactAt    DateTime? @map("first_contact_at")

  account PlatformAccount @relation(fields: [platformAccountId], references: [id])
  page    PlatformPage?   @relation(fields: [fbPageId], references: [id])
  sessions ChatbotSession[]

  @@unique([externalId])
  @@map("leads")
}

model PlatformPage {
  id                 String    @id
  name               String
  accessToken        String?   @map("access_token")
  lastSyncedAt       DateTime? @default(now()) @map("last_synced_at")
  avatarUrl          String?   @map("avatar_url")
  platformIdentityId Int?      @map("platform_identity_id")

  identity PlatformIdentity? @relation(fields: [platformIdentityId], references: [id])
  leads    Lead[]
  agents   Agent[]

  @@map("platform_pages")
}

model AuthToken {
  token     String    @id
  userId    Int       @map("user_id")
  createdAt DateTime? @default(now()) @map("created_at")
  name      String?
  expiresAt DateTime? @map("expires_at")
  isActive  Boolean?  @default(true) @map("is_active")

  user User @relation(fields: [userId], references: [id])

  @@map("auth_tokens")
}

model CampaignAiAnalysis {
  id              String   @id @default(dbgenerated("gen_random_uuid()"))
  campaignId      String   @unique @map("campaign_id")
  analysisText    String?  @map("analysis_text")
  metricsSnapshot Json?    @map("metrics_snapshot")
  createdAt       DateTime? @default(now()) @map("created_at")
  updatedAt       DateTime? @default(now()) @map("updated_at")

  campaign UnifiedCampaign @relation(fields: [campaignId], references: [id])

  @@map("campaign_ai_analysis")
}

model Agent {
  id         String    @id
  name       String
  fbPageId   String?   @map("fb_page_id")
  createdAt  DateTime? @default(now()) @map("created_at")
  lastSeenAt DateTime? @default(now()) @map("last_seen_at")

  page PlatformPage? @relation(fields: [fbPageId], references: [id])

  @@map("agents")
}

model ChatbotConfig {
  id         Int       @id @default(autoincrement())
  userId     Int       @unique @map("user_id")
  pageId     String?   @map("page_id")
  isEnabled  Boolean?  @default(false) @map("is_enabled")
  testMode   Boolean?  @default(true) @map("test_mode")
  testPsids  String[]  @default(["7302212653229178"]) @map("test_psids")
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @default(now()) @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("chatbot_config")
}

model ChatbotFlow {
  id                Int       @id @default(autoincrement())
  userId            Int       @map("user_id")
  flowKey           String    @map("flow_key")
  displayName       String    @map("display_name")
  messageType       String    @map("message_type")
  content           Json?     @default("{}")
  triggerPayloads   String[]  @default([]) @map("trigger_payloads")
  triggerKeywords   String[]  @default([]) @map("trigger_keywords")
  isEntryPoint      Boolean?  @default(false) @map("is_entry_point")
  sortOrder         Int?      @default(0) @map("sort_order")
  isActive          Boolean?  @default(true) @map("is_active")
  createdAt         DateTime? @default(now()) @map("created_at")
  updatedAt         DateTime? @default(now()) @map("updated_at")
  isDailyWelcome    Boolean?  @default(false) @map("is_daily_welcome")
  linkedAdIds       String[]  @default([]) @map("linked_ad_ids")

  user User @relation(fields: [userId], references: [id])

  @@map("chatbot_flows")
}

model ChatbotSession {
  id                String    @id @default(dbgenerated("gen_random_uuid()"))
  leadId            String?   @map("lead_id")
  pageId            String    @map("page_id")
  customerId        String    @map("customer_id")
  currentStep       String?   @default("welcome") @map("current_step")
  isActive          Boolean?  @default(true) @map("is_active")
  handedOff         Boolean?  @default(false) @map("handed_off")
  lastInteractionAt DateTime? @default(now()) @map("last_interaction_at")
  createdAt         DateTime? @default(now()) @map("created_at")

  lead Lead? @relation(fields: [leadId], references: [id])

  @@map("chatbot_sessions")
}

model DebugSyncLog {
  id           Int       @id @default(autoincrement())
  createdAt    DateTime? @default(now()) @map("created_at")
  functionName String?   @map("function_name")
  event        String?
  payload      Json?

  @@map("debug_sync_logs")
}

model AiReport {
  id             String    @id @default(dbgenerated("gen_random_uuid()"))
  type           String
  referenceId    String    @map("reference_id")
  campaignName   String    @map("campaign_name")
  metrics        Json?
  reportContent  String    @map("report_content")
  createdAt      DateTime  @default(now()) @map("created_at")
  userId         Int?      @map("user_id")

  user User? @relation(fields: [userId], references: [id])

  @@map("ai_reports")
}
